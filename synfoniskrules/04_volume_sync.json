{
  "name": "SYMFONISK Level -> Sonos Volume",
  "actions": [
    {
      "if": {
        "between": {
          "value": {
            "device": {
              "devices": ["YOUR_SYMFONISK_DEVICE_ID"],
              "component": "main",
              "capability": "switchLevel",
              "attribute": "level",
              "trigger": "Always"
            }
          },
          "start": { "integer": 0 },
          "end":   { "integer": 100 }
        },
        "then": [
          {
            "command": {
              "devices": ["YOUR_SONOS_DEVICE_ID"],
              "commands": [
                {
                  "component":  "main",
                  "capability": "audioVolume",
                  "command":    "setVolume",
                  "arguments": [
                    {
                      "device": {
                        "devices":    ["YOUR_SYMFONISK_DEVICE_ID"],
                        "component":  "main",
                        "capability": "switchLevel",
                        "attribute":  "level"
                      }
                    }
                  ]
                }
              ]
            }
          }
        ]
      }
    }
  ]
}
