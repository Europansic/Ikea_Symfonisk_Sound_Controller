{
  "name": "SYMFONISK -> Sonos Play/Pause",
  "actions": [
    {
      "if": {
        "equals": {
          "left": { "string": "pushed" },
          "right": {
            "device": {
              "devices": ["YOUR_SYMFONISK_DEVICE_ID"],
              "component": "main",
              "capability": "button",
              "attribute": "button",
              "trigger": "Always"
            }
          }
        },
        "then": [
          {
            "if": {
              "equals": {
                "left": {
                  "device": {
                    "devices": ["YOUR_SONOS_DEVICE_ID"],
                    "component": "main",
                    "capability": "mediaPlayback",
                    "attribute": "playbackStatus",
                    "trigger": "Never"
                  }
                },
                "right": { "string": "playing" }
              },
              "then": [
                {
                  "command": {
                    "devices": ["YOUR_SONOS_DEVICE_ID"],
                    "commands": [
                      { "component": "main", "capability": "mediaPlayback", "command": "pause", "arguments": [] }
                    ]
                  }
                }
              ],
              "else": [
                {
                  "command": {
                    "devices": ["YOUR_SONOS_DEVICE_ID"],
                    "commands": [
                      { "component": "main", "capability": "mediaPlayback", "command": "play", "arguments": [] }
                    ]
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ]
}
