{
  "name": "SYMFONISK -> Sonos Previous Track",
  "actions": [
    {
      "if": {
        "equals": {
          "left": { "string": "pushed_3x" },
          "right": {
            "device": {
              "devices": ["YOUR_SYMFONISK_DEVICE_ID"],
              "component": "main",
              "capability": "button",
              "attribute": "button",
              "trigger": "Always"
            }
          }
        },
        "then": [
          {
            "command": {
              "devices": ["YOUR_SONOS_DEVICE_ID"],
              "commands": [
                { "component": "main", "capability": "mediaTrackControl", "command": "previousTrack", "arguments": [] }
              ]
            }
          }
        ]
      }
    }
  ]
}
